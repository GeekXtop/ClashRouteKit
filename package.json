{
  "name": "clash-route-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @clash-route-kit/web dev",
    "serve:output": "vite --host 127.0.0.1 --port 8787 output",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "generate": "pnpm --filter @clash-route-kit/cli start generate",
    "preview": "pnpm --filter @clash-route-kit/cli start preview",
    "check": "pnpm --filter @clash-route-kit/cli start check"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
